// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  clerkId   String?   @unique   // set when Clerk is integrated
  email     String?
  name      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sessions  Session[]
}

model Session {
  id             String   @id @default(cuid())
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  mode           String   // "formula" | "branch"

  // Aggregate Metrics (Common to all games)
  maxInternalLevel Int           
  totalQuestions   Int           
  correctCount     Int           
  durationSeconds  Int           
  createdAt        DateTime      @default(now())
  
  attempts         LevelAttempt[]

  @@index([userId, mode]) // Optimization: Query history for a specific game

}

model LevelAttempt {
  id              String   @id @default(cuid())
  sessionId       String
  session         Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  // Adaptive Context
  sequence        Int      // 1, 2, 3...
  difficulty      Int      // Li: The ladder rank
  
  // Result Data
  isCorrect       Boolean
  responseTimeMs  Int      
  

  @@index([sessionId])
}